NEXT_PUBLIC_SUPABASE_URL=https://lqafvmzksaqxzqvxmfcf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxxYWZ2bXprc2FxeHpxdnhtZmNmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk5ODc0MTQsImV4cCI6MjA5NTU2MzQxNH0._zOfgkidLr9jrc1xU61EGGniQ-2RtMa3TteMteH8CpI
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Admin auth (server-side apenas — nunca exposto ao cliente)
# =============================================================================
# Senha unica para login no painel /admin
ADMIN_PASSWORD=troque-essa-senha

# String aleatoria de no minimo 32 caracteres para assinar cookies de sessao.
# Gere com: openssl rand -base64 32
SESSION_SECRET=gere-32-chars-aleatorios-aqui-pelo-amor

# =============================================================================
# OpenAI (geracao de copy via GPT-4o)
# =============================================================================
OPENAI_API_KEY=sk-proj-...

# Limite mensal em USD (opcional, soft cap aplicado em codigo)
OPENAI_MONTHLY_LIMIT_USD=50

# =============================================================================
# Shopee Affiliates (HMAC-SHA1, API GraphQL)
# =============================================================================
SHOPEE_APP_ID=
SHOPEE_SECRET=
SHOPEE_TRACKING_ID=techindica_main

# =============================================================================
# Cron (Supabase pg_cron -> /api/cron/generate-post)
# =============================================================================
# Token bearer que o pg_cron usa pra autorizar o route handler. Gere com:
# openssl rand -hex 32
CRON_SECRET=gere-um-token-aleatorio-aqui

# =============================================================================
# Site
# =============================================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# Analytics (Plausible) — opcional
# =============================================================================
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=techinidica.com

# =============================================================================
# Newsletter (Resend) — opcional
# =============================================================================
# RESEND_API_KEY=re_...
# RESEND_FROM=TechIndica <noreply@techinidica.com>
