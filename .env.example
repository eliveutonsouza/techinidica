# =============================================================================
# Prisma — PostgreSQL via Supabase
# =============================================================================
# DATABASE_URL: connection pooler (PgBouncer, porta 6543) — usado pelo app
# DIRECT_URL: conexao direta (porta 5432) — usado por prisma migrate
# Ambas em: Supabase Dashboard > Settings > Database > Connection String
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# =============================================================================
# Supabase Auth (mantido apenas para autenticacao multi-user)
# =============================================================================
# URL e chave ainda usados em src/lib/auth.ts e admin/usuarios/page.tsx (Supabase Auth)
# Para a SUPABASE_SERVICE_ROLE_KEY: Dashboard > Settings > API > service_role secret
NEXT_PUBLIC_SUPABASE_URL=https://lqafvmzksaqxzqvxmfcf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxxYWZ2bXprc2FxeHpxdnhtZmNmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk5ODc0MTQsImV4cCI6MjA5NTU2MzQxNH0._zOfgkidLr9jrc1xU61EGGniQ-2RtMa3TteMteH8CpI
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Admin auth (server-side apenas — nunca exposto ao cliente)
# =============================================================================
# Senha unica para login no painel /admin
ADMIN_PASSWORD=troque-essa-senha

# String aleatoria de no minimo 32 caracteres para assinar cookies de sessao.
# Gere com: openssl rand -base64 32
SESSION_SECRET=gere-32-chars-aleatorios-aqui-pelo-amor

# =============================================================================
# OpenAI (geracao de copy via GPT-4o)
# =============================================================================
OPENAI_API_KEY=sk-proj-...

# Limite mensal em USD (opcional, soft cap aplicado em codigo)
OPENAI_MONTHLY_LIMIT_USD=50

# =============================================================================
# Shopee Affiliates (HMAC-SHA1, API GraphQL)
# =============================================================================
SHOPEE_APP_ID=
SHOPEE_SECRET=
SHOPEE_TRACKING_ID=techindica_main

# =============================================================================
# Cron (Vercel Cron Jobs -> /api/cron/generate-post e /api/cron/shopee-fetch)
# =============================================================================
# Token bearer que o Vercel Cron usa pra autorizar o route handler. Gere com:
# openssl rand -hex 32
CRON_SECRET=gere-um-token-aleatorio-aqui

# =============================================================================
# Site
# =============================================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# Analytics (Plausible) — opcional
# =============================================================================
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=techinidica.com

# =============================================================================
# Newsletter (Resend) — opcional
# =============================================================================
# RESEND_API_KEY=re_...
# RESEND_FROM=TechIndica <noreply@techinidica.com>
